}

Table negotiation_files {
  negotiation_file_id int [pk, increment]
  negotiation_request_id int [not null, ref: > negotiation_requests.negotiation_request_id]
  uploaded_by_user_id int [not null, ref: > users.user_id]
  created_at datetime [not null]
  file_size bigint
  file_type varchar(50)
  file_url varchar(2000) [not null]
  file_name varchar(255) [not null]
}

Table negotiation_requests {
  negotiation_request_id int [pk, increment]
  negotiation_id int [not null, ref: > negotiations.negotiation_id]
  requested_contract_id int [ref: > contracts.contract_id]
  requested_quote_id int [ref: > quotes.quote_id]
  revised_contract_id int [ref: > contracts.contract_id]
  revised_quote_id int [ref: > quotes.quote_id]
  accepted_at datetime
  canceled_at datetime
  created_at datetime [not null]
  requested_at datetime [not null]
  responded_at datetime
  updated_at datetime [not null]
  status varchar(30) [not null]
  buyer_request text [not null]
  seller_memo text
  desired_lead_time_days int
  desired_unit_price bigint
}

Table negotiations {
  negotiation_id int [pk, increment]
  admin_id int [ref: > users.user_id]
  buyer_id int [not null, ref: > users.user_id]
  contract_id int [ref: > contracts.contract_id]
  quote_id int [ref: > quotes.quote_id]
  seller_id int [not null, ref: > users.user_id]
  agreed_at datetime
  closed_at datetime
  created_at datetime [not null]
  opened_at datetime [not null]
  updated_at datetime [not null]
  negotiation_type varchar(30) [not null]
  status varchar(30) [not null]
  title varchar(150) [not null]
}

Table notices {
  notice_id int [pk, increment]
  created_by_user_id int [not null, ref: > users.user_id]
  is_pinned boolean [not null]
  created_at datetime
  updated_at datetime
  title varchar(200) [not null]
  content text [not null]
}

Table notifications {
  notification_id int [pk, increment]
  is_read boolean [not null]
  reference_id int
  target_company_id int
  target_user_id int
  created_at datetime [not null]
  target_role varchar(20)
  reference_type varchar(30)
  message varchar(255) [not null]
  type notification_type_enum [not null]

  indexes {
    (target_user_id, created_at) [name: 'idx_notif_user']
    (target_company_id, created_at) [name: 'idx_notif_company']
    (target_role, created_at) [name: 'idx_notif_role']
  }
}

Table order_items {
  order_item_id int [pk, increment]
  assigned_user_id int [not null, ref: > users.user_id]
  order_id int [not null, ref: > orders.order_id]
  product_id int [ref: > products.product_id]
  product_option_id int [ref: > product_options.product_option_id]
  quantity int [not null]
  additional_price bigint [not null]
  created_at datetime [not null]
  prepared_at datetime
  total_price bigint [not null]
  unit_price bigint [not null]
  product_name varchar(150) [not null]
  option_summary varchar(255)
  product_image_url varchar(255)
  item_status order_item_status_enum [not null]

  indexes {
    order_id [name: 'idx_order_items_order_id']
    product_id [name: 'idx_order_items_product_id']
    assigned_user_id [name: 'idx_order_items_assigned_user_id']
  }
}

Table order_logs {
  order_log_id int [pk, increment]
  actor_user_id int [ref: > users.user_id]
  order_id int [not null, ref: > orders.order_id]
  created_at datetime
  updated_at datetime
  memo text
  log_type log_type_enum [not null]
  new_status order_status_enum
  previous_status order_status_enum
  process_step order_process_step_enum

  indexes {
    order_id [name: 'idx_order_logs_order_id']
    (order_id, created_at) [name: 'idx_order_logs_order_created']
    (log_type, created_at) [name: 'idx_order_logs_log_type_created']
  }
}

Table orders {
  order_id int [pk, increment]
  buyer_id int [not null, ref: > users.user_id]
  canceled_by_user_id int [ref: > users.user_id]
  contract_id int [ref: > contracts.contract_id]
  is_sample boolean [not null]
  parent_order_id int [ref: > orders.order_id]
  quote_id int [ref: > quotes.quote_id]
  seller_company_id int [not null, ref: > companies.company_id]
  agreed_at datetime
  canceled_at datetime
  created_at datetime
  delivered_at datetime
  platform_fee bigint [not null]
  shipped_at datetime
  shipping_fee bigint [not null]
  subtotal_amount bigint [not null]
  total_amount bigint [not null]
  updated_at datetime
  receiver_zipcode varchar(20)
  sender_zipcode varchar(20)
  order_no varchar(30) [not null, unique]
  receiver_phone varchar(30) [not null]
  sender_phone varchar(30)
  carrier varchar(50)
  receiver_name varchar(50) [not null]
  sender_name varchar(50)
  seller_company_name varchar(100) [not null]
  tracking_number varchar(100)
  receiver_address varchar(255) [not null]
  receiver_address_detail varchar(255)
  receiver_memo varchar(255)
  sender_address varchar(255)
  sender_address_detail varchar(255)
  canceled_reason text
  order_type order_type_enum [not null]
  payment_method payment_method_enum
  status order_status_enum [not null]
  settlement_status settlement_status_enum

  indexes {
    (buyer_id, created_at) [name: 'idx_orders_buyer_created']
    (seller_company_id, status, created_at) [name: 'idx_orders_seller_company_status_created']
  }
}

Table product_certification {
  product_certification_id int [pk, increment]
  expiry_month int
  expiry_year int
  product_id int [not null, ref: > products.product_id]
  cert_name varchar(100) [not null]
  file_url varchar(2000) [not null]
}

Table product_images {
  product_image_id int [pk, increment]
  is_main boolean [not null]
  product_option_id int [not null, ref: > product_options.product_option_id]
  sort_order int [not null]
  created_at datetime
  updated_at datetime
  image_url varchar(2000) [not null]

  indexes {
    product_option_id [name: 'idx_product_images_product_option_id']
  }
}

Table product_option_values {
  product_option_value_id int [pk, increment]
  product_option_id int [not null, ref: > product_options.product_option_id]
  sort_order int [not null]
  created_at datetime [not null]
  option_name varchar(50) [not null]
  option_value varchar(50) [not null]

  indexes {
    (product_option_id, option_name, option_value) [unique, name: 'uk_product_option_value']
    product_option_id [name: 'idx_product_option_values_product_option_id']
  }
}

Table product_options {
  product_option_id int [pk, increment]
  is_active boolean [not null]
  product_id int [not null, ref: > products.product_id]
  restock_alert_quantity int
  sample_max_quantity int
  stock_quantity int [not null]
  additional_price bigint [not null]
  created_at datetime
  sample_price bigint
  updated_at datetime
  option_label varchar(100) [not null]
  sku varchar(100)

  indexes {
    (product_id, option_label) [unique, name: 'uk_product_option_label']
    (product_id, sku) [unique, name: 'uk_product_sku']
    product_id [name: 'idx_product_options_product_id']
  }
}

Table products {
  product_id int [pk, increment]
  brand_id int [not null, ref: > brands.brand_id]
  category_id int [not null, ref: > categories.category_id]
  company_id int [not null, ref: > companies.company_id]
  is_active boolean [not null]
  lead_time_days int
  moq int [not null]
  oem_available boolean [not null]
  sample_available boolean [not null]
  seller_id int [not null, ref: > users.user_id]
  view_count int
  white_label boolean [not null]
  created_at datetime
  unit_price bigint [not null]
  updated_at datetime
  season varchar(30)
  product_eng_name varchar(150)
  product_name varchar(150) [not null]
  care_instruction varchar(1000)
  product_url varchar(2000)
  main_material varchar(255)
  material_cert varchar(255)
  description longtext
  return_policy text
}

Table quote_items {
  quote_item_id int [pk, increment]
  is_sample boolean [not null]
  quantity int [not null]
  quote_id int [not null, ref: > quotes.quote_id]
  created_at datetime [not null]
  total_price bigint [not null]
  unit_price bigint [not null]
  option_summary varchar(255)

  indexes {
    quote_id [name: 'idx_quote_items_quote_id']
  }
}

Table quotes {
  quote_id int [pk, increment]
  buyer_id int [not null, ref: > users.user_id]
  company_id int [not null, ref: > companies.company_id]
  lead_time_days int [not null]
  parent_quote_id int [ref: > quotes.quote_id]
  seller_id int [not null, ref: > users.user_id]
  sourcing_id int [not null, ref: > sourcing_requests.sourcing_request_id]
  version int [not null]
  accepted_at datetime
  created_at datetime [not null]
  expired_at datetime
  negotiated_at datetime
  shipping_fee bigint [not null]
  submitted_at datetime [not null]
  subtotal_amount bigint [not null]
  total_amount bigint [not null]
  valid_until datetime [not null]
  viewed_at datetime
  quote_no varchar(30) [not null, unique]
  status varchar(30) [not null]
  buyer_name varchar(50)
  company_name varchar(50)
  delivery_company varchar(50)
  seller_name varchar(50)
  brand_name varchar(100)
  category_name varchar(100)
  sample_available varchar(100) [not null]
  product_name varchar(150) [not null]
  material varchar(255)
  seller_memo text

  indexes {
    sourcing_id [name: 'idx_quotes_sourcing_id']
    seller_id [name: 'idx_quotes_seller_id']
    (seller_id, status, created_at) [name: 'idx_quotes_seller_status_created']
  }
}

Table settlements {
  settlement_id int [pk, increment]
  admin_id int [not null, ref: > users.user_id]
  buyer_id int [not null, ref: > users.user_id]
  order_no int [not null, ref: > orders.order_id]
  seller_id int [not null, ref: > users.user_id]
  created_at datetime [not null]
  final_amount bigint [not null]
  platform_fee bigint [not null]
  settled_at datetime [not null]
  total_amount bigint [not null]
  status varchar(50) [not null]
  receiver_name varchar(255) [not null]

  indexes {
    status [name: 'idx_settlement_status']
  }
}

Table social_accounts {
  social_account_id int [pk, increment]
  user_id int [not null, ref: > users.user_id]
  created_at datetime [not null]
  deleted_at datetime
  provider_uid varchar(255) [not null]
  provider social_provider_enum [not null]

  indexes {
    (provider, provider_uid) [unique, name: 'idx_provider_uid']
  }
}

Table sourcing_request_files {
  sourcing_request_file_id int [pk, increment]
  sourcing_request_id int [not null, ref: > sourcing_requests.sourcing_request_id]
  file_type varchar(20) [not null]
  file_url varchar(2000) [not null]
  file_name varchar(255) [not null]
}

Table sourcing_request_items {
  sourcing_request_item_id int [pk, increment]
  quantity int [not null]
  sample_quantity int
  sourcing_id int [not null, ref: > sourcing_requests.sourcing_request_id]
  option_summary varchar(255) [not null]
}

Table sourcing_requests {
  sourcing_request_id int [pk, increment]
  buyer_company_id int [not null]
  buyer_id int [not null, ref: > users.user_id]
  category_id int
  delivery_date date
  expiry_date date
  need_sample varchar(1) [not null]
  created_at datetime
  total_budget bigint
  unit_price bigint
  updated_at datetime
  type varchar(10) [not null]
  brand_name varchar(50)
  sourcing_no varchar(50) [not null, unique]
  product_name varchar(100) [not null]
  main_material varchar(255)
  detail longtext
  ref_url text
  status sourcing_request_status_enum [not null]
}

Table sourcing_suppliers {
  sourcing_supplier_id int [pk, increment]
  assigned_by int [ref: > users.user_id]
  quote_id int [ref: > quotes.quote_id]
  seller_company_id int [not null]
  sourcing_request_id int [not null, ref: > sourcing_requests.sourcing_request_id]
  approved_at datetime
  created_at datetime
  responded_at datetime
  updated_at datetime
  version bigint [not null]
  manager_note text
  seller_feedback text
  status sourcing_supplier_status_enum [not null]

  indexes {
    (sourcing_request_id, seller_company_id) [unique, name: 'uk_sourcing_supplier']
  }
}

Table supplier_profile {
  company_id int [pk]
  auto_assign_enabled boolean [not null]
  created_at datetime [not null]
  updated_at datetime [not null]
  sourcing_type supplier_sourcing_type_enum [not null]
}

Table supplier_statistics {
  company_id int [pk]
  response_rate decimal(5,2) [not null]
  total_requests int [not null]
  total_responses int [not null]
  updated_at datetime [not null]
}

Table toss_payment_orders {
  toss_payment_id varchar(200) [not null, ref: > toss_payments.toss_payment_id]
  order_id varchar(255)
}

Table toss_payments {
  toss_payment_id varchar(200) [pk]
  amount bigint [not null]
  approved_at datetime
  canceled_at datetime
  requested_at datetime [not null]
  va_bank_code varchar(10)
  status varchar(20) [not null]
  method varchar(30)
  va_account_number varchar(30)
  va_customer_name varchar(50)
  toss_order_id varchar(64) [not null]
  cancel_resaon varchar(2000)
  va_due_date varchar(255)
}

Table toss_refunds {
  toss_refund_id int [pk, increment]
  amount bigint [not null]
  canceled_at datetime [not null]
  toss_payment_id varchar(200) [not null, ref: > toss_payments.toss_payment_id]
  cancel_reason text
}

Table user_preferred_categories {
  preferred_category_id int [pk, increment]
  category_id int [not null, ref: > categories.category_id]
  user_id int [not null, ref: > users.user_id]
  created_at datetime [not null]

  indexes {
    (user_id, category_id) [unique, name: 'uk_user_category']
  }
}

Table users {
  user_id int [pk, increment]
  company_id int [ref: > companies.company_id]
  default_receiving_address_id int [ref: > addresses.address_id]
  default_shipping_address_id int [ref: > addresses.address_id]
  failed_login_attempts tinyint [not null, default: 0]
  created_at datetime
  deleted_at datetime
  last_login_at datetime
  updated_at datetime
  name varchar(20)
  phone varchar(20)
  last_login_ip varchar(45)
  email varchar(100) [not null, unique]
  profile_image_url varchar(2000)
  password varchar(255)
  business_role user_business_role_enum [not null]
  role user_role_enum [not null]
  status user_status_enum [not null]
}

Table wishlist_folders {
  wishlist_folder_id int [pk, increment]
  is_default boolean [not null]
  sort_order int [not null]
  user_id int [not null, ref: > users.user_id]
  created_at datetime
  updated_at datetime
  folder_name varchar(50) [not null]

  indexes {
    (user_id, folder_name) [unique, name: 'uk_wishlist_folder_user_name']
    user_id [name: 'idx_wishlist_folders_user_id']
  }
}

Table wishlists {
  wishlist_id int [pk, increment]
  product_id int [not null, ref: > products.product_id]
  user_id int [not null, ref: > users.user_id]
  wishlist_folder_id int [not null, ref: > wishlist_folders.wishlist_folder_id]
  created_at datetime
  updated_at datetime

  indexes {
    (wishlist_folder_id, product_id) [unique, name: 'uk_wishlist_folder_product']
    wishlist_folder_id [name: 'idx_wishlists_folder_id']
    user_id [name: 'idx_wishlists_user_id']
    product_id [name: 'idx_wishlists_product_id']
  }
}
