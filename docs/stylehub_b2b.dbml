//////////////////////////////////////////////////
// TABLES
//////////////////////////////////////////////////

Table addresses {
  address_id int [pk, increment]
  company_id int [not null, ref: > companies.company_id]
  created_at datetime
  deleted_at datetime
  updated_at datetime
  zipcode varchar(20)
  address_name varchar(50) [not null]
  address varchar(255) [not null]
  address_detail varchar(255)
}

Table bank_transfer_payment_orders {
  order_id int
  bank_transfer_payment_id bigint [not null, ref: > bank_transfer_payments.id]
}

Table bank_transfer_payments {
  id bigint [pk, increment]
  canceled_at datetime
  confirmed_at datetime
  created_at datetime [not null]
  deposit_account_id bigint [not null, ref: > deposit_accounts.id]
  deposit_deadline datetime [not null]
  cancel_reason varchar(255)
  depositor_name varchar(255) [not null]
  status bank_transfer_payment_status [not null]
}

Table brands {
  brand_id int [pk, increment]
  company_id int [not null, ref: > companies.company_id]
  created_at datetime
  updated_at datetime
  brand_name varchar(100) [not null]
  brand_logo_url varchar(2000)
}

Table cart_items {
  cart_item_id int [pk, increment]
  is_checked boolean [not null]
  product_option_id int [not null, ref: > product_options.product_option_id]
  quantity int [not null]
  user_id int [not null, ref: > users.user_id]
  created_at datetime
  updated_at datetime
  cart_type cart_type_enum [not null]

  indexes {
    (user_id, product_option_id, cart_type) [unique, name: 'uk_cart_user_option_type']
  }
}

Table categories {
  category_id int [pk, increment]
  depth int [not null]
  is_active boolean [not null]
  parent_id int [ref: > categories.category_id]
  sort_order int [not null]
  category_name varchar(50) [not null]
}

Table companies {
  company_id int [pk, increment]
  answer_average double
  avg_lead_time_days int
  default_return_address_id int [ref: > addresses.address_id]
  base_shipping_fee bigint [not null]
  created_at datetime
  deleted_at datetime
  free_shipping_threshold bigint
  updated_at datetime
  business_number varchar(20) [not null, unique]
  representative_phone varchar(20)
  representative_name varchar(50)
  name varchar(100) [not null]
  business_license_url varchar(2000)
  description varchar(2000)
  logo_url varchar(2000)
  address varchar(255)
  address_detail varchar(255)
  website_url varchar(255)
  seller_status company_seller_status_enum [not null]
  status company_status_enum [not null]
  store_type store_type_enum
}

Table company_bank_accounts {
  bank_account_id int [pk, increment]
  company_id int [not null, ref: > companies.company_id]
  is_default boolean [not null]
  is_verified boolean [not null]
  created_at datetime
  deleted_at datetime
  updated_at datetime
  account_holder varchar(50) [not null]
  account_number varchar(50) [not null]
  bank_name varchar(50) [not null]

  indexes {
    company_id [name: 'idx_company_id']
    (company_id, is_default) [name: 'idx_company_is_default']
  }
}

Table company_handled_categories {
  company_handled_category_id int [pk, increment]
  category_id int [not null]
  company_id int [not null]
  created_at datetime [not null]

  indexes {
    (company_id, category_id) [unique, name: 'uk_company_category']
  }
}

Table contract_items {
  contract_item_id int [pk, increment]
  contract_id int [not null, ref: > contracts.contract_id]
  product_id int [ref: > products.product_id]
  product_option_id int [ref: > product_options.product_option_id]
  quantity int [not null]
  created_at datetime [not null]
  total_price bigint [not null]
  unit_price bigint [not null]
  product_name varchar(150) [not null]
  material varchar(255)
  option_summary varchar(255)
}

Table contract_signatures {
  contract_signature_id int [pk, increment]
  contract_id int [not null, ref: > contracts.contract_id]
  signer_id int [not null, ref: > users.user_id]
  signed_at datetime [not null]
  signed_ip varchar(45)
  signature_text varchar(100)
  signed_user_agent varchar(500)
  signature_image_url varchar(2000)
  signature_hash varchar(255)
  signer_role signer_role_enum [not null]
}

Table contracts {
  contract_id int [pk, increment]
  company_id int [not null, ref: > companies.company_id]
  delivery_date date [not null]
  parent_contract_id int [ref: > contracts.contract_id]
  quote_id int [not null, ref: > quotes.quote_id]
  version int [not null]
  buyer_signed_at datetime
  canceled_at datetime
  completed_at datetime
  contract_amount bigint [not null]
  created_at datetime [not null]
  seller_signed_at datetime
  shipping_fee bigint [not null]
  submitted_at datetime
  contract_no varchar(30) [not null, unique]
  pdf_hash varchar(64)
  buyer_company_name varchar(100) [not null]
  seller_company_name varchar(100) [not null]
  contract_name varchar(150)
  payment_terms varchar(500) [not null]
  pdf_url varchar(2000)
  contract_hash varchar(255)
  return_policy text [not null]
  special_terms text
  status contract_status_enum [not null]
}

Table delivery_tracking_status {
  id int [pk, increment]
  order_id int [not null, unique]
  created_at datetime [not null]
  synced_at datetime [not null]
  carrier_id varchar(50) [not null]
  last_event_time varchar(50)
  last_location varchar(100)
  tracking_number varchar(100) [not null]
  last_description varchar(255)
  last_status delivery_last_status_enum [not null]
}

Table deposit_accounts {
  id bigint [pk, increment]
  active boolean [not null]
  created_at datetime [not null]
  updated_at datetime [not null]
  account_holder varchar(255) [not null]
  account_number varchar(255) [not null]
  bank_name varchar(255) [not null]
}

Table dispute_files {
  dispute_file_id int [pk, increment]
  dispute_id int [not null, ref: > disputes.dispute_id]
  dispute_response_id int [ref: > dispute_responses.dispute_response_id]
  uploaded_by_user_id int [not null, ref: > users.user_id]
  created_at datetime [not null]
  file_size bigint
  file_type varchar(50)
  file_url varchar(2000) [not null]
  file_name varchar(255) [not null]

  indexes {
    dispute_id [name: 'idx_dispute_file']
    dispute_response_id [name: 'idx_dispute_response_file']
  }
}

Table dispute_products {
  dispute_product_id int [pk, increment]
  claim_quantity int
  dispute_id int [not null, ref: > disputes.dispute_id]
  order_item_id int [not null, ref: > order_items.order_item_id]
  created_at datetime [not null]
  resolution_amount bigint
  requested_action varchar(30)
  resolution_type varchar(30)
  claim_reason text
}

Table dispute_responses {
  dispute_response_id int [pk, increment]
  dispute_id int [not null, ref: > disputes.dispute_id]
  responder_id int [not null, ref: > users.user_id]
  created_at datetime [not null]
  content text [not null]
  responder_role dispute_response_role_enum [not null]
  status dispute_flow_status_enum [not null]

  indexes {
    (dispute_id, created_at) [name: 'idx_dispute_created']
    responder_id [name: 'idx_responder']
  }
}

Table disputes {
  dispute_id int [pk, increment]
  admin_id int [ref: > users.user_id]
  buyer_id int [not null, ref: > users.user_id]
  order_id int [not null, ref: > orders.order_id]
  seller_company_id int [not null, ref: > companies.company_id]
  created_at datetime
  received_at datetime [not null]
  resolution_amount bigint
  resolved_at datetime
  updated_at datetime
  title varchar(150) [not null]
  admin_memo text
  buyer_claim text [not null]
  dispute_type dispute_type_enum [not null]
  requested_action dispute_requested_action_enum [not null]
  resolution_type dispute_resolution_type_enum
  status dispute_flow_status_enum [not null]

  indexes {
    order_id [name: 'idx_dispute_order']
    (buyer_id, status) [name: 'idx_dispute_buyer_status']
    (seller_company_id, status) [name: 'idx_dispute_seller_company_status']
    (admin_id, status) [name: 'idx_dispute_admin_status']
    (dispute_type, status) [name: 'idx_dispute_type_status']
  }
}

Table faqs {
  faq_id int [pk, increment]
  sort_order int [not null]
  created_at datetime
  updated_at datetime
  category varchar(50)
  answer varchar(1000) [not null]
  question varchar(1000) [not null]
}

Table inquiries {
  inquiry_id int [pk, increment]
  assigned_admin_id int [ref: > users.user_id]
  company_id int [not null, ref: > companies.company_id]
  created_by_user_id int [not null, ref: > users.user_id]
  last_sender_id int [ref: > users.user_id]
  closed_at datetime
  created_at datetime
  last_message_at datetime
  title varchar(100) [not null]
  last_message_preview varchar(255)
  category inquiry_category_enum [not null]
  status inquiry_status_enum [not null]
}

Table inquiry_message_reads {
  message_read_id int [pk, increment]
  message_id int [not null, ref: > inquiry_messages.message_id]
  user_id int [not null, ref: > users.user_id]
  read_at datetime

  indexes {
    (message_id, user_id) [name: 'idx_message_user']
  }
}

Table inquiry_messages {
  message_id int [pk, increment]
  inquiry_id int [not null, ref: > inquiries.inquiry_id]
  sender_id int [not null, ref: > users.user_id]
  created_at datetime
